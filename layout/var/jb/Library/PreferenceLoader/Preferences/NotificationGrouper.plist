
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>title</key>
    <string>NotificationGrouper</string>
    <key>items</key>
    <array>
        <dict>
            <key>cell</key>
            <string>PSSwitchCell</string>
            <key>default</key>
            <true/>
            <key>defaults</key>
            <string>com.yourname.notificationgrouper</string>
            <key>key</key>
            <string>enabled</string>
            <key>label</key>
            <string>启用通知归纳</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSliderCell</string>
            <key>default</key>
            <integer>300</integer>
            <key>defaults</key>
            <string>com.yourname.notificationgrouper</string>
            <key>key</key>
            <string>aggregationWindow</string>
            <key>label</key>
            <string>聚合时间窗口（秒）</string>
            <key>min</key>
            <integer>60</integer>
            <key>max</key>
            <integer>900</integer>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSButtonCell</string>
            <key>label</key>
            <string>重置设置</string>
            <key>action</key>
            <string>resetSettings</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>关于</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSLinkCell</string>
            <key>label</key>
            <string>GitHub</string>
            <key>url</key>
            <string>https://github.com/Dabaosom/NotificationGrouper</string>
        </dict>
    </array>
</dict>
</plist>
